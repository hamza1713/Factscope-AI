# ==============================================================================
# ⚠️ SECURITY WARNING: BACKEND USE ONLY ⚠️
# ==============================================================================
# NEVER prefix these variables with VITE_, NEXT_PUBLIC_, or REACT_APP_.
# NEVER use these variables in frontend code or client-side bundles.
# These keys provide direct access to your billing and must remain strictly on the server.

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="your_gemini_api_key_here"

# Optional: Set the port for the local Express backend (default: 3001)
# PORT=3001
